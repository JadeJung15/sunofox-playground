rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function userOwnsDoc(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function validSiteStatsCreate() {
      return (
        request.resource.data.keys().hasOnly(['total']) && request.resource.data.total == 1
      ) || (
        request.resource.data.keys().hasOnly(['count']) && request.resource.data.count == 1
      );
    }

    function validSiteStatsUpdate() {
      return (
        resource.data.keys().hasOnly(['total']) &&
        request.resource.data.keys().hasOnly(['total']) &&
        request.resource.data.total == resource.data.total + 1
      ) || (
        resource.data.keys().hasOnly(['count']) &&
        request.resource.data.keys().hasOnly(['count']) &&
        request.resource.data.count == resource.data.count + 1
      );
    }

    function validTestStatsCreate() {
      return request.resource.data.keys().hasOnly(['likes']) &&
        request.resource.data.likes == 1;
    }

    function validTestStatsUpdate() {
      return resource.data.keys().hasOnly(['likes']) &&
        request.resource.data.keys().hasOnly(['likes']) &&
        request.resource.data.likes == resource.data.likes + 1;
    }

    function validUserCreate(userId) {
      return userOwnsDoc(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.points == 1000
        && request.resource.data.totalScore == 0
        && request.resource.data.keys().hasOnly([
          'uid',
          'nickname',
          'originalName',
          'originalEmail',
          'emoji',
          'unlockedEmojis',
          'points',
          'inventory',
          'totalScore',
          'discoveredItems',
          'activePet',
          'unlockedPets',
          'nicknameChanged',
          'lastNicknameChange',
          'nameColor',
          'arcadeStats',
          'arcadeWeekly',
          'quests',
          'createdAt'
        ]);
    }

    function validNicknameUpdate(userId) {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      let nextNickname = request.resource.data.nickname;
      let nextPoints = request.resource.data.points;
      let currentPoints = resource.data.points;

      return userOwnsDoc(userId)
        && changedKeys.hasOnly(['nickname', 'nicknameChanged', 'points'])
        && nextNickname is string
        && nextNickname.size() >= 2
        && nextNickname.size() <= 10
        && nextNickname.matches('.*\\S.*')
        && request.resource.data.nicknameChanged == true
        && nextPoints is int
        && (
          (!resource.data.nicknameChanged && nextPoints == currentPoints) ||
          (resource.data.nicknameChanged == true && nextPoints == currentPoints - 5000)
        );
    }

    function validNameColorUpdate(userId) {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      let nextColor = request.resource.data.nameColor;
      let nextPoints = request.resource.data.points;
      let currentPoints = resource.data.points;

      return userOwnsDoc(userId)
        && changedKeys.hasOnly(['nameColor', 'points'])
        && nextColor is string
        && nextColor in [
          '#333333', '#1e293b', '#3b82f6', '#8b5cf6', '#10b981',
          '#f59e0b', '#f97316', '#f43f5e', '#ec4899', '#0ea5e9'
        ]
        && nextPoints is int
        && nextPoints == currentPoints - 1000;
    }

    function validEmojiUpdate(userId) {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      let nextEmoji = request.resource.data.emoji;
      let nextPoints = request.resource.data.points;
      let currentPoints = resource.data.points;
      let currentUnlocked = resource.data.unlockedEmojis;
      let nextUnlocked = request.resource.data.unlockedEmojis;

      return userOwnsDoc(userId)
        && changedKeys.hasOnly(['emoji', 'unlockedEmojis', 'points'])
        && nextEmoji is string
        && nextPoints is int
        && currentUnlocked is list
        && nextUnlocked is list
        && nextUnlocked.hasAll(currentUnlocked)
        && nextUnlocked.hasAll([nextEmoji])
        && (
          (nextEmoji == '🐱' || nextEmoji == '🐶') && nextPoints == currentPoints - 200 ||
          (nextEmoji == '🦊' || nextEmoji == '🐰' || nextEmoji == '🌸' || nextEmoji == '🌻') && nextPoints == currentPoints - 300 ||
          (nextEmoji == '🐹' || nextEmoji == '🐣' || nextEmoji == '🍀') && nextPoints == currentPoints - 400 ||
          (nextEmoji == '🐼' || nextEmoji == '🐨' || nextEmoji == '🐧' || nextEmoji == '☀️' || nextEmoji == '🌙') && nextPoints == currentPoints - 500 ||
          (nextEmoji == '🐯' || nextEmoji == '🦁' || nextEmoji == '🌈' || nextEmoji == '🔥') && nextPoints == currentPoints - 1000 ||
          nextEmoji == '🐺' && nextPoints == currentPoints - 1000 ||
          nextEmoji == '🦈' && nextPoints == currentPoints - 1500 ||
          (nextEmoji == '🦖' || nextEmoji == '🌌') && nextPoints == currentPoints - 2000 ||
          nextEmoji == '🐲' && nextPoints == currentPoints - 2500 ||
          nextEmoji == '✨' && nextPoints == currentPoints - 3000 ||
          nextEmoji == '⚡' && nextPoints == currentPoints - 4000 ||
          (nextEmoji == '👑' || nextEmoji == '🧿') && nextPoints == currentPoints - 5000 ||
          nextEmoji == '💎' && nextPoints == currentPoints - 10000
        );
    }

    function validActivePetUpdate(userId) {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      let nextPet = request.resource.data.activePet;
      let unlockedPets = resource.data.unlockedPets;

      return userOwnsDoc(userId)
        && changedKeys.hasOnly(['activePet'])
        && nextPet is string
        && unlockedPets is list
        && unlockedPets.hasAll([nextPet]);
    }

    function validAdoptPetUpdate(userId) {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      let nextPet = request.resource.data.activePet;
      let currentPoints = resource.data.points;
      let nextPoints = request.resource.data.points;
      let currentUnlocked = resource.data.unlockedPets;
      let nextUnlocked = request.resource.data.unlockedPets;

      return userOwnsDoc(userId)
        && changedKeys.hasOnly(['activePet', 'unlockedPets', 'points'])
        && currentUnlocked is list
        && nextUnlocked is list
        && nextUnlocked.size() == currentUnlocked.size() + 1
        && nextUnlocked.hasAll(currentUnlocked)
        && nextUnlocked.hasAll([nextPet])
        && (
          nextPet == 'F_WHITE' && nextPoints == currentPoints - 5000 ||
          nextPet == 'F_FIRE' && nextPoints == currentPoints - 5000 ||
          nextPet == 'F_SHADOW' && nextPoints == currentPoints - 15000 ||
          nextPet == 'F_AURORA' && nextPoints == currentPoints - 15000 ||
          nextPet == 'F_CELESTIAL' && nextPoints == currentPoints - 50000
        );
    }

    function validProfileStyleSet(userId) {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();

      return userOwnsDoc(userId)
        && (
          changedKeys.hasOnly(['activeAura']) &&
          (
            request.resource.data.activeAura == 'NONE' ||
            (resource.data.unlockedAuras is list && resource.data.unlockedAuras.hasAll([request.resource.data.activeAura]))
          ) ||
          changedKeys.hasOnly(['activeBorder']) &&
          (
            request.resource.data.activeBorder == 'NONE' ||
            (resource.data.unlockedBorders is list && resource.data.unlockedBorders.hasAll([request.resource.data.activeBorder]))
          ) ||
          changedKeys.hasOnly(['activeBackground']) &&
          (
            request.resource.data.activeBackground == 'NONE' ||
            (resource.data.unlockedBackgrounds is list && resource.data.unlockedBackgrounds.hasAll([request.resource.data.activeBackground]))
          )
        );
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() 
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isSignedIn() 
        && (resource.data.uid == request.auth.uid || isAdmin());

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() 
          && request.resource.data.uid == request.auth.uid;
        allow delete: if isSignedIn() 
          && (resource.data.uid == request.auth.uid || isAdmin());
      }
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if validUserCreate(userId) || isAdmin();
      allow update: if isAdmin()
        || validNicknameUpdate(userId)
        || validNameColorUpdate(userId)
        || validEmojiUpdate(userId)
        || validActivePetUpdate(userId)
        || validAdoptPetUpdate(userId)
        || validProfileStyleSet(userId);
      allow delete: if isAdmin();
    }

    // 테스트 통계(좋아요) 규칙
    match /testStats/{testId} {
      allow read: if true;
      allow create: if isSignedIn() && validTestStatsCreate();
      allow update: if isSignedIn() && validTestStatsUpdate();
    }

    // 활동 이력(로그) 규칙
    match /pointLogs/{logId} {
      allow read: if isAdmin();
      allow create: if false;
    }

    // 공지사항 규칙
    match /announcements/{newsId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == "6LVa2hs5ICSi4cgNjRBAx3dA2In2";
    }

    // 방문자 통계 규칙
    match /siteStats/{statsId} {
      allow read: if true;
      allow create: if validSiteStatsCreate();
      allow update: if validSiteStatsUpdate();
    }

    match /songDrafts/{draftId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /tests/{testId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /results/{resultId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /stats/{statId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
