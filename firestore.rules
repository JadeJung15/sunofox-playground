rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() 
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isSignedIn() 
        && (resource.data.uid == request.auth.uid || isAdmin());

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() 
          && request.resource.data.uid == request.auth.uid;
        allow delete: if isSignedIn() 
          && (resource.data.uid == request.auth.uid || isAdmin());
      }
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // 테스트 통계(좋아요) 규칙
    match /testStats/{testId} {
      allow read: if true;
      allow create, update: if isSignedIn(); 
    }

    // 활동 이력(로그) 규칙
    match /pointLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    // 공지사항 규칙
    match /announcements/{newsId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == "6LVa2hs5ICSi4cgNjRBAx3dA2In2";
    }

    // 방문자 통계 규칙
    match /siteStats/{statsId} {
      allow read, write: if true;
    }

    match /songDrafts/{draftId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }
  }
}
